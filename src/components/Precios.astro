---
// src/components/Precios.astro
import { t } from "../i18n/ui.js";

const pathname = Astro.url.pathname;
const lang = pathname.includes("/en") ? "en" : "es";
const textos = t[lang];

const LINK_RESERVA = "https://app.sporttia.com/scs/3287/profile";
---

<section class="py-20 bg-gray-50 px-6">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 max-w-3xl mx-auto">
            <span
                class="text-amarillo-acento font-bold italic tracking-wider uppercase text-sm"
            >
                {textos["precios.etiqueta"]}
            </span>
            <h2
                class="font-titulos text-4xl md:text-5xl text-azul-oscuro mt-2 mb-4 uppercase italic skew-x-[-2deg]"
            >
                {textos["precios.titulo"]}
            </h2>
            <p class="text-gray-600 leading-relaxed">
                {textos["precios.subtitulo"]}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
            <div
                class="bg-white rounded-xl shadow-lg p-8 border border-gray-100 text-center flex flex-col hover:-translate-y-1 transition-transform"
            >
                <h3 class="text-2xl font-bold text-azul-oscuro mb-3">
                    {textos["precios.t1_titulo"]}
                </h3>
                <p class="text-gray-500 text-sm mb-6 flex-grow">
                    {textos["precios.t1_desc"]}
                </p>
                <div class="mb-2">
                    <span class="text-5xl font-bold text-azul-principal"
                        >{textos["precios.t1_precio"]}</span
                    >
                </div>
                <p class="text-sm text-gray-400 mb-2 uppercase tracking-wide">
                    / {textos["precios.por_persona"]}
                </p>
                <p
                    class="font-bold text-gray-700 mb-8 pb-8 border-b border-gray-100"
                >
                    {textos["precios.t1_total"]}
                </p>

                <ul class="text-left space-y-4 mb-8 text-sm text-gray-600">
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_tiempo"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_cancelacion"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_cambio"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_kiosko"]}
                    </li>
                </ul>
                <a
                    href={LINK_RESERVA}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-auto block w-full py-3 bg-amarillo-acento text-azul-oscuro font-bold rounded-lg uppercase tracking-wide hover:bg-yellow-400 transition-colors"
                >
                    {textos["precios.boton"]}
                </a>
            </div>

            <div
                class="bg-azul-principal rounded-xl shadow-lg p-8 border border-azul-principal text-center flex flex-col hover:-translate-y-1 transition-transform relative z-10"
            >
                <h3 class="text-2xl font-bold text-white mb-3">
                    {textos["precios.t2_titulo"]}
                </h3>
                <p class="text-blue-50 text-sm mb-6 flex-grow">
                    {textos["precios.t2_desc"]}
                </p>
                <div class="mb-2">
                    <span class="text-5xl font-bold text-amarillo-acento"
                        >{textos["precios.t2_precio"]}</span
                    >
                </div>
                <p class="text-sm text-blue-100 mb-2 uppercase tracking-wide">
                    / {textos["precios.por_persona"]}
                </p>
                <p
                    class="font-bold text-white mb-8 pb-8 border-b border-white/20"
                >
                    {textos["precios.t2_total"]}
                </p>

                <ul class="text-left space-y-4 mb-8 text-sm text-white">
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-amarillo-acento shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_tiempo"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-amarillo-acento shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_cancelacion"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-amarillo-acento shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_cambio"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-amarillo-acento shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_luz"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-amarillo-acento shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_bolas"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-amarillo-acento shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_kiosko"]}
                    </li>
                </ul>
                <a
                    href={LINK_RESERVA}
                    target="_blank"
