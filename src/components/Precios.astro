                </div>
                <p class="text-sm text-gray-400 mb-2 uppercase tracking-wide">
                    / {textos["precios.por_persona"]}
                </p>
                <p
                    class="font-bold text-gray-700 mb-8 pb-8 border-b border-gray-100"
                >
                    {textos["precios.t3_total"]}
                </p>

                <ul class="text-left space-y-4 mb-8 text-sm text-gray-600">
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_tiempo"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_cancelacion"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_cambio"]}
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-green-500 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        {textos["precios.b_kiosko"]}
                    </li>
                </ul>
                <a
                    href={LINK_RESERVA}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-auto block w-full py-3 bg-amarillo-acento text-azul-oscuro font-bold rounded-lg uppercase tracking-wide hover:bg-yellow-400 transition-colors"
