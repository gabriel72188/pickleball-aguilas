                >
                    {textos["precios.boton"]}
                </a>
            </div>

            <div
                class="bg-white rounded-xl shadow-lg p-8 border border-gray-100 text-center flex flex-col hover:-translate-y-1 transition-transform"
            >
                <h3 class="text-2xl font-bold text-azul-oscuro mb-3">
                    {textos["precios.t3_titulo"]}
                </h3>
                <p class="text-gray-500 text-sm mb-6 flex-grow">
