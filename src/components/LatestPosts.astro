---
// src/components/LatestPosts.astro
import { getCollection } from "astro:content";
import { t } from "../i18n/ui.js";

const { lang } = Astro.props;
const textos = t[lang];

// 1. Obtenemos TODOS los posts
const allPosts = await getCollection("blog", ({ id, data }) => {
    return (
        id.startsWith(`${lang}/`) &&
        data.draft !== true &&
        data.pubDate <= new Date()
    );
});

// 2. Ordenamos por fecha
const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 3. Configuración de paginación
const postsPerPage = 4;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
---

{
    sortedPosts.length > 0 && (
        <section
            class="max-w-6xl mx-auto px-6 py-12 mt-2"
            id="latest-posts-section"
        >
            {/* Encabezado */}
            <div class="text-center mb-10 max-w-3xl mx-auto">
                <span class="text-amarillo-acento font-bold uppercase tracking-widest text-sm flex items-center justify-center gap-2 mb-2 italic">
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
                        />
                    </svg>
                    {textos["latestposts.badge"]}
                </span>
                <h2 class="text-2xl md:text-3xl font-titulos uppercase italic skew-x-[-2deg] text-azul-oscuro mb-4 tracking-tight">
                    {textos["latestposts.title"]}
                </h2>
                <p class="text-gray-500 leading-relaxed text-sm md:text-base font-light">
                    {textos["latestposts.desc_start"]}
                    <span class="text-amarillo-acento font-medium">
                        {textos["latestposts.desc_highlight"]}
                    </span>
                    {textos["latestposts.desc_end"]}
                </p>
            </div>

            {/* Contenedor de Páginas */}
            <div id="posts-container">
                {Array.from({ length: totalPages }).map((_, pageIndex) => (
                    <div
                        class={`grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8 post-page ${pageIndex === 0 ? "grid" : "hidden"}`}
                        data-page={pageIndex + 1}
                    >
                        {sortedPosts
                            .slice(
                                pageIndex * postsPerPage,
                                (pageIndex + 1) * postsPerPage,
                            )
                            .map((post) => {
                                const rawId = post.slug || post.id;
                                const cleanSlug = rawId
                                    .replace(`${lang}/`, "")
                                    .replace(/\.mdx?$/, "");

                                return (
                                    <a
                                        href={`/${lang}/blog/${cleanSlug}`}
                                        class="group flex flex-col gap-3"
                                        title={post.data.title}
                                    >
                                        {/* Contenedor de la Imagen */}
                                        <div class="relative overflow-hidden rounded-xl shadow-sm group-hover:shadow-md transition-all duration-300 aspect-video bg-gray-100">
                                            <img
                                                src={post.data.image}
                                                alt={post.data.title}
                                                class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500"
                                                loading="lazy"
                                            />
                                            <div class="absolute inset-0 bg-azul-oscuro/0 group-hover:bg-azul-oscuro/20 transition-colors duration-300" />
                                        </div>

                                        {/* Título del Post */}
                                        <h3 class="font-bold text-azul-oscuro group-hover:text-amarillo-acento transition-colors text-sm md:text-base leading-tight line-clamp-2">
                                            {post.data.title}
                                        </h3>
                                    </a>
                                );
                            })}
                    </div>
                ))}
            </div>

            {/* Botones de Paginación */}
            {totalPages > 1 && (
                <div
                    class="flex justify-center gap-2 mt-10"
                    id="pagination-controls"
                >
                    {Array.from({ length: totalPages }).map((_, i) => (
                        <button
                            class={`w-8 h-8 rounded-md flex items-center justify-center text-sm font-bold transition-colors pagination-btn ${i === 0 ? "bg-azul-principal text-white" : "bg-gray-100 text-gray-400 hover:bg-gray-200"}`}
                            data-target={i + 1}
                        >
                            {i + 1}
                        </button>
                    ))}
                </div>
            )}
        </section>
    )
}

<script>
    function setupPagination() {
        const container = document.getElementById("latest-posts-section");
        if (!container) return;

        const buttons = container.querySelectorAll(".pagination-btn");
        const pages = container.querySelectorAll(".post-page");

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const target = btn.getAttribute("data-target");

                // Cambiar estado de botones
                buttons.forEach((b) => {
                    b.classList.remove("bg-azul-principal", "text-white");
                    b.classList.add("bg-gray-100", "text-gray-400");
                });
                btn.classList.remove("bg-gray-100", "text-gray-400");
                btn.classList.add("bg-azul-principal", "text-white");

                // Cambiar visibilidad de páginas
                pages.forEach((page) => {
                    if (page.getAttribute("data-page") === target) {
                        page.classList.remove("hidden");
                        page.classList.add("grid");
                    } else {
                        page.classList.add("hidden");
                        page.classList.remove("grid");
                    }
                });
            });
        });
    }

    setupPagination();
    document.addEventListener("astro:after-swap", setupPagination);
</script>
