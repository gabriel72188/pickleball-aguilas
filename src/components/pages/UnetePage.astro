---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../Navbar.astro";
import Footer from "../Footer.astro";
import LatestPosts from "../LatestPosts.astro";
import { t } from "../../i18n/ui.js";

const { lang } = Astro.props;
const textos = t[lang];
---

<Layout title={textos["unete.head_title"]} lang={lang}>
  <Navbar />

  <main
    class="min-h-[85vh] bg-gray-50 py-20 px-6 flex items-center justify-center relative overflow-hidden"
  >
    <div
      class="absolute top-0 left-0 w-full h-64 bg-azul-oscuro -skew-y-3 origin-top-left -z-0"
    >
    </div>

    <div
      class="max-w-xl w-full bg-white rounded-2xl shadow-2xl p-8 md:p-12 relative z-10 border border-gray-100"
    >
      <div class="text-center mb-10">
        <h1
          class="font-titulos text-4xl md:text-5xl text-azul-principal mb-4 uppercase tracking-tighter"
        >
          {textos["unete.titulo"]}
        </h1>
        <p class="text-gray-600">
          {textos["unete.subtitulo"]}
        </p>
      </div>

      <div
        id="msg-exito"
        class="hidden mb-6 p-4 bg-green-50 text-green-800 border border-green-200 rounded-lg text-center font-medium"
      >
        {textos["msg.exito"]}
      </div>

      <div
        id="msg-duplicado"
        class="hidden mb-6 p-4 bg-yellow-50 text-yellow-800 border border-yellow-200 rounded-lg text-center font-medium"
      >
        {textos["msg.duplicado"]}
      </div>

      <div
        id="msg-error"
        class="hidden mb-6 p-4 bg-red-50 text-red-800 border border-red-200 rounded-lg text-center font-medium"
      >
        {textos["msg.error"]}
      </div>

      <form action="/guardar_datos.php" method="POST" class="space-y-6">
        <div style="position: absolute; left: -5000px;" aria-hidden="true">
          <label for="apellido_falso">No rellenes este campo</label>
          <input
            type="text"
            id="apellido_falso"
            name="apellido_falso"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <div>
          <label
            for="nombre"
            class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2"
          >
            {textos["form.nombre"]}
          </label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-azul-principal focus:ring-2 focus:ring-azul-principal/20 outline-none transition-all bg-gray-50 focus:bg-white"
            placeholder={lang === "es" ? "Ej. Juan Gómez" : "E.g. Juan Gomez"}
          />
        </div>

        <div>
          <label
            for="correo"
            class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2"
          >
            {textos["form.correo"]}
          </label>
          <input
            type="email"
            id="correo"
            name="correo"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-azul-principal focus:ring-2 focus:ring-azul-principal/20 outline-none transition-all bg-gray-50 focus:bg-white"
            placeholder="email@ejemplo.com"
          />
        </div>

        <div>
          <label
            for="telefono"
            class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2"
          >
            {textos["form.telefono"]}
          </label>
          <input
            type="tel"
            id="telefono"
            name="telefono"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-azul-principal focus:ring-2 focus:ring-azul-principal/20 outline-none transition-all bg-gray-50 focus:bg-white"
            placeholder="+34 600 000 000"
          />
        </div>

        <div class="flex items-start gap-3 pt-2">
          <input
            type="checkbox"
            id="privacidad"
            name="privacidad"
            required
            class="mt-1 w-5 h-5 accent-azul-principal cursor-pointer"
          />
          <label for="privacidad" class="text-sm text-gray-500 cursor-pointer">
            {textos["form.privacidad"]}
          </label>
        </div>

        <button
          type="submit"
          class="w-full bg-amarillo-acento text-azul-oscuro font-titulos text-xl py-4 rounded-lg shadow-lg hover:bg-yellow-400 hover:-translate-y-1 transition-all mt-4 uppercase tracking-wide"
        >
          {textos["form.boton"]}
        </button>
      </form>
    </div>
  </main>

  <LatestPosts lang={lang} />
  <Footer lang={lang} />
</Layout>

<script>
  // Función para detectar el estado en la URL y mostrar mensajes
  const manejarEstadoFormulario = () => {
    const params = new URLSearchParams(window.location.search);
    const estado = params.get("estado");

    if (!estado) return;

    // Mostrar la caja correspondiente
    if (estado === "exito") {
      document.getElementById("msg-exito")?.classList.remove("hidden");
    } else if (estado === "duplicado") {
      document.getElementById("msg-duplicado")?.classList.remove("hidden");
    } else if (estado === "error" || estado === "invalido") {
      document.getElementById("msg-error")?.classList.remove("hidden");
    }

    window.history.replaceState({}, document.title, window.location.pathname);
  };

  manejarEstadoFormulario();

  document.addEventListener("astro:page-load", manejarEstadoFormulario);
</script>
