---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../Navbar.astro";
import Footer from "../Footer.astro";
import { t } from "../../i18n/ui.js";

const { lang } = Astro.props;
const textos = t[lang];
---

<Layout title={textos["about.head_title"]} lang={lang}>
    <Navbar />

    <!-- HEADER con imagen de fondo -->
    <header
        class="relative bg-azul-oscuro py-24 px-6 flex flex-col items-center justify-center text-center overflow-hidden min-h-[40vh]"
    >
        <img
            src="/imagen-fondo2.jpg"
            alt=""
            class="absolute inset-0 w-full h-full object-cover z-0"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-azul-oscuro/80 to-azul-oscuro/60 z-10"
        >
        </div>
        <div
            class="relative z-20 max-w-4xl mx-auto flex flex-col items-center justify-center"
        >
            <h1
                class="font-titulos text-5xl md:text-6xl text-white uppercase tracking-tighter shadow-sm mb-4"
            >
                {textos["about.hero_title"]}
            </h1>
            <p class="text-white text-lg md:text-xl max-w-3xl leading-relaxed">
                {textos["about.hero_desc"]}
            </p>
        </div>
    </header>

    <main class="py-16 md:py-24 px-6 overflow-hidden">
        <!-- SECCIÓN EQUIPAZO -->
        <section class="max-w-6xl mx-auto mb-24">
            <div class="flex flex-col md:flex-row items-center relative">
                <!-- Columna Izquierda: Fondo oscuro e imagen (offset) -->
                <div class="w-full md:w-1/2 relative md:static mb-12 md:mb-0">
                    <!-- Caja oscura de fondo con logo -->
                    <div
                        class="w-[90%] md:w-[450px] h-80 bg-[#333] absolute top-[-20px] md:top-[-40px] left-0 md:-left-8 z-0 flex flex-col pt-8 items-center rounded-lg"
                    >
                        <span
                            class="text-amarillo-acento text-4xl font-titulos tracking-widest px-4 uppercase block text-center"
                        >
                            Pickleball Águilas
                        </span>
                        <span
                            class="text-white text-xl tracking-widest px-4 uppercase block text-center mt-1"
                        >
                            Isla del Fraile
                        </span>
                    </div>

                    <!-- Imagen superpuesta -->
                    <img
                        src="/jose-carla.webp"
                        alt={textos["about.img_team_alt"]}
                        class="w-3/4 md:w-80 h-[400px] object-cover rounded shadow-lg relative z-10 block ml-8 md:ml-16 mt-16 border-4 border-white"
                    />
                </div>

                <!-- Columna Derecha: Tarjeta blanca -->
                <div class="w-full md:w-1/2 relative z-20">
                    <div
                        class="bg-white p-8 md:p-12 shadow-2xl rounded-sm border-t-2 border-amarillo-acento md:-ml-8 relative"
                    >
                        <span
                            class="text-amarillo-acento text-sm font-bold uppercase tracking-wider mb-2 block"
                        >
                            {textos["about.badge"]}
                        </span>
                        <h2
                            class="font-titulos text-4xl text-azul-oscuro uppercase italic mb-6"
                        >
                            {textos["about.team_title"]}
                        </h2>

                        <div
                            class="space-y-4 text-gray-600 mb-8 leading-relaxed"
                        >
                            <p>{textos["about.team_desc1"]}</p>
                            <p class="font-medium text-azul-oscuro italic">
                                {textos["about.team_desc2"]}
                            </p>
                        </div>

                        <h3
                            class="font-titulos text-2xl text-azul-oscuro uppercase mb-4"
                        >
                            {textos["about.mission_title"]}
                        </h3>
                        <div
                            class="space-y-4 text-gray-600 leading-relaxed text-sm"
                        >
                            <p>{textos["about.mission_desc1"]}</p>
                            <p>{textos["about.mission_desc2"]}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN VÍDEO (Fondo pista) -->
        <section
            class="max-w-7xl mx-auto rounded-3xl overflow-hidden relative shadow-2xl bg-zinc-900 border-4 border-azul-oscuro"
        >
            <!-- Imagen de fondo que simula la textura -->
            <div
                class="absolute inset-0 opacity-20 bg-repeat bg-center"
                style="background-image: url('/pattern-pista.png'); z-index: 0;"
            >
            </div>

            <div
                class="relative z-20 py-16 md:py-24 flex justify-center items-center"
            >
                <!-- Thumbnail del video -->
                <div
                    class="relative group cursor-pointer w-full max-w-4xl px-4"
                >
                    <img
                        src="/video-thumbnail.webp"
                        alt={textos["about.img_video_alt"]}
                        class="w-full h-auto rounded shadow-2xl border-2 border-white/20 group-hover:border-amarillo-acento transition-colors duration-300 object-cover"
                    />
                    <!-- Overlay de Play -->
                    <div
                        class="absolute inset-0 flex items-center justify-center"
                    >
                        <div
                            class="w-16 h-16 md:w-24 md:h-24 bg-amarillo-acento rounded-full flex items-center justify-center shadow-xl transform group-hover:scale-110 transition-transform duration-300"
                        >
                            <svg
                                class="w-8 h-8 md:w-12 md:h-12 text-azul-oscuro ml-2"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path d="M4 4l12 6-12 6z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer lang={lang} />
</Layout>
