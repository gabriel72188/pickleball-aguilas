---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../Navbar.astro";
import Footer from "../Footer.astro";
import LatestPosts from "../LatestPosts.astro";
import { t } from "../../i18n/ui.js";

const { lang } = Astro.props;
const textos = t[lang];
---

<Layout title={textos["about.head_title"]} lang={lang}>
    <Navbar />

    <header
        class="relative bg-azul-oscuro py-24 px-6 flex flex-col items-center justify-center text-center overflow-hidden min-h-[40vh]"
    >
        <img
            src="/imagen-fondo2.jpg"
            alt=""
            class="absolute inset-0 w-full h-full object-cover z-0 opacity-50"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-black/60 to-black/30 z-10"
        >
        </div>
        <div
            class="relative z-20 max-w-4xl mx-auto flex flex-col items-center justify-center"
        >
            <h1
                class="font-titulos text-5xl md:text-6xl text-white uppercase tracking-tighter shadow-sm mb-6 italic"
            >
                {textos["about.hero_title"]}
            </h1>
            <p
                class="text-xl text-gray-200 font-light max-w-3xl leading-relaxed"
            >
                {textos["about.hero_desc"]}
            </p>
        </div>
    </header>

    <main class="py-16 md:py-24 px-6 overflow-hidden bg-gray-50">
        <section class="max-w-7xl mx-auto mb-24">
            <div
                class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center"
            >
                <div
                    class="lg:col-span-7 space-y-8 pr-0 lg:pr-10 order-2 lg:order-1"
                >
                    <div>
                        <span
                            class="text-amarillo-acento font-bold uppercase tracking-widest text-sm mb-3 block"
                        >
                            {textos["about.badge"]}
                        </span>
                        <h2
                            class="text-4xl md:text-5xl font-titulos text-azul-oscuro uppercase italic tracking-tight"
                        >
                            {textos["about.team_title"]}
                        </h2>
                    </div>

                    <div
                        class="text-gray-600 leading-relaxed space-y-5 text-lg"
                    >
                        <p>{textos["about.team_desc1"]}</p>

                        <div
                            class="bg-blue-50/80 p-6 rounded-2xl border-l-4 border-amarillo-acento shadow-sm my-6"
                        >
                            <p class="font-medium text-azul-oscuro italic">
                                {textos["about.team_desc2"]}
                            </p>
                        </div>
                    </div>

                    <div class="pt-4 border-t border-gray-200">
                        <h3 class="text-2xl font-bold text-azul-oscuro mb-3">
                            {textos["about.mission_title"]}
                        </h3>
                        <p class="text-gray-600 leading-relaxed mb-2">
                            {textos["about.mission_desc1"]}
                        </p>
                        <p class="text-gray-600 leading-relaxed">
                            {textos["about.mission_desc2"]}
                        </p>
                    </div>
                </div>

                <div
                    class="lg:col-span-5 relative order-1 lg:order-2 px-6 lg:px-0"
                >
                    <div
                        class="absolute inset-0 bg-amarillo-acento rounded-[2.5rem] transform translate-x-4 translate-y-6 md:translate-x-6 md:translate-y-8 -z-10"
                    >
                    </div>
                    <img
                        src="/jose-carla.webp"
                        alt={textos["about.img_team_alt"]}
                        class="w-full h-[400px] md:h-[550px] object-cover rounded-[2.5rem] shadow-xl border-4 border-white"
                    />
                </div>
            </div>
        </section>

        <section
            class="max-w-6xl mx-auto rounded-[3rem] overflow-hidden relative shadow-2xl bg-azul-oscuro"
        >
            <div
                class="absolute inset-0 opacity-10 bg-repeat bg-center mix-blend-overlay"
                style="background-image: url('/pattern-pista.png'); z-index: 0;"
            >
            </div>

            <div
                class="relative z-20 py-20 px-6 flex flex-col justify-center items-center"
            >
                <h3
                    class="text-white font-titulos text-3xl mb-8 uppercase italic text-center"
                >
                    {textos["about.video_title"]}
                </h3>

                <div
                    class="relative group cursor-pointer w-full max-w-4xl rounded-2xl overflow-hidden shadow-2xl border border-white/10"
                >
                    <img
                        src="/video-thumbnail.webp"
                        alt={textos["about.img_video_alt"]}
                        class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700"
                    />

                    <div
                        class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors duration-300 flex items-center justify-center"
                    >
                        <div
                            class="w-20 h-20 md:w-24 md:h-24 bg-amarillo-acento rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(250,204,21,0.4)] transform group-hover:scale-110 transition-all duration-300"
                        >
                            <svg
                                class="w-10 h-10 md:w-12 md:h-12 text-azul-oscuro ml-2"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path d="M4 4l12 6-12 6z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <LatestPosts lang={lang} />
    <Footer lang={lang} />
</Layout>
