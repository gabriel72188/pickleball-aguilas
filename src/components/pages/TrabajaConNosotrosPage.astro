---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../Navbar.astro";
import Footer from "../Footer.astro";
import { t } from "../../i18n/ui.js";
import { empresasColaboradoras } from "../../i18n/empresas.js";

const { lang } = Astro.props;
const textos = t[lang];
---

<Layout title={textos["work.head_title"]} lang={lang}>
    <Navbar />

    <!-- HEADER con imagen de fondo -->
    <header class="relative bg-azul-oscuro py-24 px-6 flex flex-col items-center justify-center text-center overflow-hidden min-h-[40vh]">
        <img src="/imagen-fondo2.jpg" alt="" class="absolute inset-0 w-full h-full object-cover z-0" />
        <div class="absolute inset-0 bg-gradient-to-b from-azul-oscuro/80 to-azul-oscuro/60 z-10"></div>
        <div class="relative z-20 max-w-4xl mx-auto flex flex-col items-center justify-center">
            <h1 class="font-titulos text-5xl md:text-6xl text-white uppercase tracking-tighter shadow-sm mb-4">
                {textos["work.hero_title"]}
            </h1>
        </div>
    </header>

    <main class="py-16 px-6 max-w-7xl mx-auto relative">
        <!-- SECCIÓN INTRO -->
        <section class="text-center max-w-4xl mx-auto mb-16 space-y-6">
            <p class="text-gray-500 uppercase tracking-widest text-sm mb-2 font-semibold">
                {textos["work.intro_subtitle"]}
            </p>
            <h2 class="font-titulos text-3xl md:text-4xl text-azul-oscuro italic mb-6">
                {textos["work.intro_h2"]}
            </h2>
            <p class="text-gray-600 leading-relaxed text-lg">
                {textos["work.intro_p1"]}
            </p>
            <p class="font-bold text-azul-oscuro text-xl my-4">
                {textos["work.intro_p2"]}
            </p>
            <p class="text-gray-600 leading-relaxed">
                {textos["work.intro_p3"]}
            </p>
            
            <img src="/img-empresas/jugadores-voleibol.webp" alt={textos["work.img_alt"]} class="w-full max-w-2xl mx-auto h-auto mt-12 rounded-lg shadow-xl border-4 border-azul-oscuro" />
        </section>

        <hr class="w-2/3 mx-auto border-gray-200 border-2 my-16" />

        <!-- SECCIÓN MÚLTIPLES FORMAS -->
        <section class="text-center max-w-3xl mx-auto mb-20 space-y-6">
            <h3 class="font-titulos text-2xl uppercase text-azul-oscuro tracking-wide mb-4">
                {textos["work.formas_title"]}
            </h3>
            <p class="text-gray-600 leading-relaxed mb-6">
                {textos["work.formas_p1"]}
            </p>
            
            <div class="mt-4">
                <a href="mailto:tu-email@pickleball.com" class="font-bold text-azul-oscuro hover:text-azul-principal border-b-2 border-amarillo-acento pb-1 transition-colors uppercase">
                    {textos["work.contact"]}
                </a>
            </div>
        </section>

        <!-- SECCIÓN EMPRESAS COLABORADORAS -->
        <section class="mb-12 px-2 sm:px-0">
            <div class="text-center mb-16">
                <h3 class="font-titulos text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-amarillo-acento uppercase italic leading-none drop-shadow-md break-words">
                    <span class="text-gray-400 text-xl sm:text-2xl md:text-3xl lg:text-4xl block not-italic mb-2 drop-shadow-none">{textos["work.colab_title"]}</span>
                    {textos["work.colab_subtitle"]}
                </h3>
            </div>

            <!-- GRID de Empresas -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
                {empresasColaboradoras.map((empresa) => (
                    <div class="bg-white flex flex-col items-center text-center px-6 py-8 border-t-4 border-amarillo-acento rounded-b-xl shadow-xl hover:-translate-y-2 transition-transform duration-300">
                        <!-- Wrapper para el logo -->
                        <div class="h-28 flex items-center justify-center mb-6 w-full">
                            <img src={empresa.logo} alt={empresa.nombre} class="max-h-full max-w-full object-contain" />
                        </div>
                        
                        <h4 class="font-titulos text-azul-oscuro text-2xl uppercase mb-4 italic underline decoration-gray-300 decoration-1 underline-offset-4">
                            {empresa.nombre}
                        </h4>
                        
                        <div class="text-gray-600 text-sm leading-relaxed mb-8 flex-grow space-y-3">
                            {empresa[lang].descripcion.map((parrafo) => (
                                <p>{parrafo}</p>
                            ))}
                        </div>
                        
                        <a href={empresa.url} target="_blank" rel="noopener noreferrer" class="bg-amarillo-acento hover:bg-yellow-400 text-azul-oscuro font-bold rounded-full py-2.5 px-6 shadow-md transition-colors w-full uppercase text-sm">
                            {empresa[lang].btnText}
                        </a>
                    </div>
                ))}
            </div>

            <!-- Footer final colaboraciones -->
            <div class="text-center max-w-4xl mx-auto mt-24">
                <p class="font-titulos text-2xl md:text-3xl text-azul-oscuro uppercase italic tracking-wide">
                    {textos["work.footer_text"]}
                </p>
            </div>
        </section>

    </main>

    <Footer lang={lang} />
</Layout>
