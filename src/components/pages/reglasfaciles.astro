---
// src/components/pages/reglasfaciles.astro
import Layout from "../../layouts/Layout.astro";
import Navbar from "../Navbar.astro";
import Footer from "../Footer.astro";
import LatestPosts from "../LatestPosts.astro";
import { t } from "../../i18n/ui.js";

const { lang } = Astro.props;
const textos = t[lang];
---

<Layout title={textos["reglas.head_title"]} lang={lang}>
    <Navbar />

    <header
        class="relative bg-azul-oscuro py-24 px-6 flex items-center justify-center text-center overflow-hidden"
    >
        <img
            src="/imagen-fondo2.jpg"
            alt=""
            class="absolute inset-0 w-full h-full object-cover z-0"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-azul-oscuro/95 via-azul-oscuro/80 to-azul-oscuro/95 z-10"
        >
        </div>
        <div class="relative z-20 max-w-4xl mx-auto">
            <h1
                class="font-titulos text-5xl md:text-6xl text-white uppercase tracking-tighter shadow-sm mb-6"
            >
                {textos["reglas.hero_title"]}
                <span class="text-amarillo-acento"
                    >{textos["reglas.hero_highlight"]}</span
                >
            </h1>
            <p class="text-2xl text-gray-200 font-light max-w-2xl mx-auto">
                {textos["reglas.hero_subtitle"]}
            </p>
        </div>
    </header>

    <main class="bg-gray-50 pb-24">
        <section class="max-w-4xl mx-auto px-6 py-16 text-center">
            <span
                class="text-amarillo-acento font-bold uppercase tracking-widest text-sm mb-4 block"
                >Antes de saltar a la pista</span
            >
            <h2 class="text-3xl md:text-4xl font-bold text-azul-oscuro mb-6">
                {textos["reglas.intro_title"]}
            </h2>
            <p class="text-lg text-gray-600 leading-relaxed">
                {textos["reglas.intro_desc"]}
            </p>
            <div class="w-24 h-1 bg-amarillo-acento mx-auto mt-10 rounded-full">
            </div>
        </section>

        <section
            class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8"
        >
            <article
                class="relative bg-gradient-to-br from-azul-oscuro to-[#132247] p-10 rounded-[2rem] shadow-xl overflow-hidden group hover:-translate-y-2 hover:shadow-2xl hover:shadow-azul-oscuro/40 transition-all duration-300 border border-white/10"
            >
                <div
                    class="absolute -right-4 -bottom-8 text-[14rem] font-black text-white/[0.03] select-none pointer-events-none group-hover:scale-110 group-hover:text-white/[0.06] transition-transform duration-500 leading-none"
                >
                    1
                </div>

                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex items-center gap-4 mb-6">
                        <div
                            class="bg-white/10 p-3 rounded-2xl text-amarillo-acento group-hover:bg-amarillo-acento group-hover:text-azul-oscuro transition-colors duration-300"
                        >
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                            </svg>
                        </div>
                        <h3
                            class="text-2xl font-bold text-amarillo-acento uppercase tracking-wider leading-tight"
                        >
                            {textos["reglas.rule1_title"]}
                        </h3>
                    </div>
                    <div
                        class="text-blue-100/90 leading-relaxed text-lg whitespace-pre-line group-hover:text-white transition-colors duration-300"
                    >
                        {textos["reglas.rule1_desc"]}
                    </div>
                </div>
            </article>

            <article
                class="relative bg-gradient-to-br from-azul-oscuro to-[#132247] p-10 rounded-[2rem] shadow-xl overflow-hidden group hover:-translate-y-2 hover:shadow-2xl hover:shadow-azul-oscuro/40 transition-all duration-300 border border-white/10"
            >
                <div
                    class="absolute -right-4 -bottom-8 text-[14rem] font-black text-white/[0.03] select-none pointer-events-none group-hover:scale-110 group-hover:text-white/[0.06] transition-transform duration-500 leading-none"
                >
                    2
                </div>

                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex items-center gap-4 mb-6">
                        <div
                            class="bg-white/10 p-3 rounded-2xl text-amarillo-acento group-hover:bg-amarillo-acento group-hover:text-azul-oscuro transition-colors duration-300"
                        >
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-2xl font-bold text-amarillo-acento uppercase tracking-wider leading-tight"
                        >
                            {textos["reglas.rule2_title"]}
                        </h3>
                    </div>
                    <div
                        class="text-blue-100/90 leading-relaxed text-lg whitespace-pre-line group-hover:text-white transition-colors duration-300"
                    >
                        {textos["reglas.rule2_desc"]}
                    </div>
                </div>
            </article>

            <article
                class="relative bg-gradient-to-br from-azul-oscuro to-[#132247] p-10 rounded-[2rem] shadow-xl overflow-hidden group hover:-translate-y-2 hover:shadow-2xl hover:shadow-azul-oscuro/40 transition-all duration-300 border border-white/10"
            >
                <div
                    class="absolute -right-4 -bottom-8 text-[14rem] font-black text-white/[0.03] select-none pointer-events-none group-hover:scale-110 group-hover:text-white/[0.06] transition-transform duration-500 leading-none"
                >
                    3
                </div>

                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex items-center gap-4 mb-6">
                        <div
                            class="bg-white/10 p-3 rounded-2xl text-amarillo-acento group-hover:bg-amarillo-acento group-hover:text-azul-oscuro transition-colors duration-300"
                        >
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-2xl font-bold text-amarillo-acento uppercase tracking-wider leading-tight"
                        >
                            {textos["reglas.rule3_title"]}
                        </h3>
                    </div>
                    <div
                        class="text-blue-100/90 leading-relaxed text-lg whitespace-pre-line group-hover:text-white transition-colors duration-300"
                    >
                        {textos["reglas.rule3_desc"]}
                    </div>
                </div>
            </article>

            <article
                class="relative bg-gradient-to-br from-azul-oscuro to-[#132247] p-10 rounded-[2rem] shadow-xl overflow-hidden group hover:-translate-y-2 hover:shadow-2xl hover:shadow-azul-oscuro/40 transition-all duration-300 border border-white/10"
            >
                <div
                    class="absolute -right-4 -bottom-8 text-[14rem] font-black text-white/[0.03] select-none pointer-events-none group-hover:scale-110 group-hover:text-white/[0.06] transition-transform duration-500 leading-none"
                >
                    4
                </div>

                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex items-center gap-4 mb-6">
                        <div
                            class="bg-white/10 p-3 rounded-2xl text-amarillo-acento group-hover:bg-amarillo-acento group-hover:text-azul-oscuro transition-colors duration-300"
                        >
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-2xl font-bold text-amarillo-acento uppercase tracking-wider leading-tight"
                        >
                            {textos["reglas.rule4_title"]}
                        </h3>
                    </div>
                    <div
                        class="text-blue-100/90 leading-relaxed text-lg whitespace-pre-line group-hover:text-white transition-colors duration-300"
                    >
                        {textos["reglas.rule4_desc"]}
                    </div>
                </div>
            </article>
        </section>

        <section class="max-w-4xl mx-auto px-6 mt-20">
            <div
                class="bg-white p-12 rounded-3xl shadow-lg border border-gray-100 text-center relative overflow-hidden"
            >
                <div
                    class="absolute top-0 right-0 w-64 h-64 bg-amarillo-acento/10 rounded-full blur-3xl -mr-20 -mt-20"
                >
                </div>

                <h2
                    class="relative z-10 text-3xl font-bold text-azul-oscuro mb-4"
                >
                    {textos["reglas.outro_title"]}
                </h2>
                <p
                    class="relative z-10 text-lg text-gray-600 mb-8 max-w-2xl mx-auto"
                >
                    {textos["reglas.outro_desc"]}
                </p>

                <div
                    class="relative z-10 flex flex-col sm:flex-row gap-4 justify-center"
                >
                    <a
                        href={`/${lang}/contacto`}
                        class="inline-flex justify-center items-center px-8 py-4 bg-azul-oscuro text-white font-bold rounded-full hover:bg-azul-principal transition-colors shadow-md text-lg"
                    >
                        {textos["reglas.outro_btn1"]}
                    </a>
                </div>
            </div>
        </section>
    </main>

    <LatestPosts lang={lang} />
    <Footer lang={lang} />
</Layout>
