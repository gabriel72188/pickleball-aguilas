---
// src/components/QueEs.astro
import { t } from "../i18n/ui.js";

const pathname = Astro.url.pathname;
const lang = pathname.includes("/en") ? "en" : pathname.includes("/de") ? "de" : pathname.includes("/fr") ? "fr" : "es";
const textos = t[lang];

const enlaceQueEs = { es: "/es/que-es-pickleball", en: "/en/que-es-pickleball", de: "/de/que-es-pickleball", fr: "/fr/que-es-pickleball" };
const enlace_que_es = enlaceQueEs[lang];
---

<section
  class="py-16 px-6 bg-azul-oscuro text-white relative overflow-hidden"
  id="que-es"
>
  <div
    class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 border-[1px] border-amarillo-acento/20 rounded-full"
  >
  </div>
  <div
    class="absolute top-10 right-10 w-40 h-40 border-[1px] border-amarillo-acento/30 rounded-full"
  >
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-10">
      <span
        class="inline-block bg-amarillo-acento text-azul-oscuro font-extrabold uppercase px-4 py-1 mb-4 transform -skew-x-12"
      >
        {textos["quees.badge"]}
      </span>
      <h2
        class="font-titulos text-4xl md:text-5xl text-amarillo-acento uppercase tracking-wide mb-2"
      >
        {textos["quees.titulo"]}
      </h2>
      <p class="text-xl md:text-2xl text-gray-300 font-light italic">
        {textos["quees.subtitulo"]}
      </p>
    </div>

    <div
      class="max-w-sm mx-auto mb-16 rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] border border-white/10 relative group bg-black"
    >
      <video
        class="w-full aspect-[9/16] object-cover"
        controls
        poster="/poster-video.png"
      >
        <source src="/introvideo.mp4" type="video/mp4" />
        Tu navegador no soporta el reproductor de vídeo.
      </video>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <a
        href={enlace_que_es}
        class="flex flex-col items-center text-center group block cursor-pointer"
      >
        <div
          class="w-20 h-20 bg-amarillo-acento text-azul-oscuro rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
        >
          <svg
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M12 20v-6M6 14A6 6 0 0 1 12 8h0a6 6 0 0 1 6 6v0a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v0z"
            ></path><circle cx="12" cy="5" r="2"></circle></svg
          >
        </div>
        <h3
          class="font-bold text-xl mb-3 text-white group-hover:text-amarillo-acento transition-colors"
        >
          {textos["quees.p1.tit"]}
        </h3>
        <p class="text-gray-400 group-hover:text-gray-300 transition-colors">
          {textos["quees.p1.desc"]}
        </p>
      </a>

      <a
        href={enlace_que_es}
        class="flex flex-col items-center text-center group block cursor-pointer"
      >
        <div
          class="w-20 h-20 bg-amarillo-acento text-azul-oscuro rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
        >
          <svg
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="18" height="12" x="3" y="6" rx="2"></rect><path
              d="M12 6v12"></path><path d="M3 12h18"></path></svg
          >
        </div>
        <h3
          class="font-bold text-xl mb-3 text-white group-hover:text-amarillo-acento transition-colors"
        >
          {textos["quees.p2.tit"]}
        </h3>
        <p class="text-gray-400 group-hover:text-gray-300 transition-colors">
          {textos["quees.p2.desc"]}
        </p>
      </a>

      <a
        href={enlace_que_es}
        class="flex flex-col items-center text-center group block cursor-pointer"
      >
        <div
          class="w-20 h-20 bg-amarillo-acento text-azul-oscuro rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
        >
          <svg
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle
              cx="9"
              cy="7"
              r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
              d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
          >
        </div>
        <h3
          class="font-bold text-xl mb-3 text-white group-hover:text-amarillo-acento transition-colors"
        >
          {textos["quees.p3.tit"]}
        </h3>
        <p class="text-gray-400 group-hover:text-gray-300 transition-colors">
          {textos["quees.p3.desc"]}
        </p>
      </a>
    </div>
  </div>
</section>
