---
// src/components/Footer.astro
interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
import { t } from "../i18n/ui.js";

const es = lang === "es";
---

<footer
  class="bg-gray-950 text-gray-400 py-12 px-6 border-t border-white/5 relative overflow-hidden"
>
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-amarillo-acento/30">
  </div>

  <div
    class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-10 text-center md:text-left items-start"
  >
    <div class="flex flex-col items-center md:items-start gap-4">
      <a
        href={`/${lang}/`}
        class="inline-block hover:opacity-80 transition-opacity"
      >
        <img
          src="/logo-circular.png"
          alt="Logo Pickleball Águilas Resort"
          class="w-40 md:w-32 h-auto object-contain shrink-0"
        />
      </a>

      <p class="text-xs mt-2">
        © {new Date().getFullYear()} Pickleball Águilas Resort.<br />
        {es ? "Todos los derechos reservados." : "All rights reserved."}
      </p>
    </div>

    <div class="text-sm">
      <h5
        class="font-semibold text-white mb-3 uppercase tracking-wider text-xs"
      >
        {es ? "Ubicación" : "Location"}
      </h5>
      <p>Calle D, 1.</p>
      <p>Urbanización Isla del Fraile.</p>
      <p>30880 Águilas, Murcia, España.</p>
    </div>

    <div class="text-sm border-t md:border-t-0 md:border-l border-white/10 pt-6 md:pt-0 md:pl-8">
      <h5 class="font-semibold text-white mb-4 uppercase tracking-wider text-xs">
        {es ? "Enlaces" : "Links"}
      </h5>
      <ul class="flex flex-col gap-3 items-center md:items-start text-sm">
        <li>
          <a href={`/${lang}/preguntas-frecuentes`} class="hover:text-amarillo-acento transition-colors">
            {t[lang]['footer.faq']}
          </a>
        </li>
        <li>
          <a href={`/${lang}/que-es-pickleball`} class="hover:text-amarillo-acento transition-colors">
            {t[lang]['footer.que_es']}
          </a>
        </li>
        <li>
          <a href={`/${lang}/quienes-somos`} class="hover:text-amarillo-acento transition-colors">
            {t[lang]['footer.quienes_somos']}
          </a>
        </li>
        <li>
          <a href={`/${lang}/trabaja-con-nosotros`} class="hover:text-amarillo-acento transition-colors">
            {t[lang]['footer.trabaja']}
          </a>
        </li>
      </ul>
    </div>

    <div class="text-sm border-t md:border-t-0 md:border-l border-white/10 pt-6 md:pt-0 md:pl-8">
      <h5 class="font-semibold text-white mb-4 uppercase tracking-wider text-xs">
        Legal
      </h5>
      <ul class="flex flex-col gap-3 items-center md:items-start text-sm">
        <li>
          <a href={`/${lang}/politica-de-cookies`} class="hover:text-amarillo-acento transition-colors">
            {t[lang]['footer.cookies']}
          </a>
        </li>
        <li>
          <a href={`/${lang}/politica-de-privacidad`} class="hover:text-amarillo-acento transition-colors">
            {t[lang]['footer.privacidad']}
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
